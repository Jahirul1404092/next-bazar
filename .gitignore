# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/
venv/
env/
.venv/

# ---- LARGE files that are REGENERATED by the pipeline ----
# These are NOT committed — GitHub Actions rebuilds them each run.

# Raw xlsx files (44MB+, re-downloaded by scraper)
data/raw_xlsx/

# Feature-engineered data (45MB+, regenerated by process_data.py)
data/all_features.csv
data/features/

# Trained model files (100MB+, retrained by model.py)
models/

# Model output forecasts (regenerated)
outputs/

# ---- FILES that ARE committed (source of truth) ----
# data/raw_daily/*.csv    — scraped daily CSVs (~10MB, incremental)
# data/all_prices_raw.csv — merged raw data
# data/all_prices_clean.csv — cleaned data
# dashboard_data.js       — generated dashboard data
# dashboard.html          — dashboard page
# update_state.json       — pipeline state tracking

# Logs
*.log
scheduler.pid

# Local-only files (not needed on GitHub)
_run_update.bat
setup_task_scheduler.bat
start_scheduler.bat
scheduler.py

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Misc
New folder/
*.txt
!requirements.txt
diagnostic_report*.txt
run_py_output.txt
Procfile
